# ==============================================================================
# Expert28 Gym Prototype — Environment Configuration Template
# Duplicate this file to '.env' and fill in your development credentials.
# ==============================================================================

# 🌐 Application Config
# The base URL of the client application.
# Fallback to local development port if running locally.
VITE_APP_URL=http://localhost:5173

# 💳 Stripe Payment Credentials
# Stripe Secret Key (Starts with sk_test_ for development). Required for backend api/ endpoints.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe Publishable Key (Starts with pk_test_ for development). Optional (used for client-side integrations).
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ⚡ Supabase Configuration
# Your Supabase Project API endpoint (e.g., https://yourprojectref.supabase.co).
VITE_SUPABASE_URL=https://your_project_ref.supabase.co

# Supabase Anonymous Key (safe to share on client side, utilizes Row Level Security).
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role Key (bypasses Row Level Security - KEEP PRIVATE, server-side only).
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
